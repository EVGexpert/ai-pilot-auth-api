# ============================================================
# AI Pilot Auth API — Environment Variables
# ============================================================
# Для production обязательны: DATABASE_PATH, JWT_SECRET, DEPLOY_HEALTH_TOKEN
# ============================================================

# Режим окружения (development/production)
# В production приложение не стартует без обязательных переменных
NODE_ENV=development

# ⚠️ JWT secret — ОБЯЗАТЕЛЕН В PRODUCTION
# Должен быть СТАБИЛЬНЫМ между деплоями, иначе все существующие сессии
# станут невалидными. Минимальная длина: 32 символа.
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=change-me-to-random-string-min-32-chars

# ⚠️ Путь к SQLite-файлу — ОБЯЗАТЕЛЕН В PRODUCTION
# Для Docker обязательно использовать путь внутри volume: /app/data/aipilot.db
# В development по умолчанию: ./data/aipilot.db
# Защита: production не примет пути /tmp, /src, /dev/shm
DATABASE_PATH=./data/aipilot.db

# ⚠️ Deploy healthcheck token — ОБЯЗАТЕЛЕН В PRODUCTION
# Используется deploy.yml для проверки целостности БД через /api/health/db
# Сгенерировать: openssl rand -hex 32
DEPLOY_HEALTH_TOKEN=change-me-to-random-string

# Длительность access JWT (для refresh-token flow)
# Можно задать в формате: 15m, 1h, 7d
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# SMTP для подтверждения email (опционально)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-password

# URL нашего сервиса
APP_URL=https://pilotsite.ru

# Gateway token (для создания временных токенов и уведомлений)
GATEWAY_TOKEN=f8186e8d77460feeb735a8dbc48e659c9b05c7f10b114fd554d6fd7a8f8e76e3
GATEWAY_WS=ws://localhost:18789
